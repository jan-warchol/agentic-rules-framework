{
  "name": "check-agent-rules",
  "version": "0.12.0",
  "description": "Check if the agent's actions comply with project rules defined in agent-rules.yaml, and enforce them using hooks. Requires python and uv package manager.",
  "author": {
    "name": "Jan Warchoł",
    "email": "jan.warchol@gmail.com",
    "url": "https://github.com/jan-warchol"
  },
  "repository": "https://github.com/jan-warchol/agentic-rules-framework",
  "license": "Apache-2.0",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT} ${CLAUDE_PLUGIN_ROOT}/log_related_events.py"
          },
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT} ${CLAUDE_PLUGIN_ROOT}/check_agent_rules.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT} ${CLAUDE_PLUGIN_ROOT}/log_related_events.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT} ${CLAUDE_PLUGIN_ROOT}/log_related_events.py"
          }
        ]
      }
    ]
  }
}
